  let tmiInfo='';if(baseImpos>0){let cur2=0,active2=b.tr[b.tr.length-1];for(const t of b.tr){if(baseImpos>cur2&&(t.max===Infinity||baseImpos<=t.max)){active2=t;break;}cur2=t.max;}const c=stc(active2.t);tmiInfo=`<div class="tmi-row"><span>Tranche marginale active :</span><span class="tmi-badge-s" style="background:${c.bg};color:${c.fg}">${Math.round(active2.t*100)} %</span><span style="color:var(--gray-300);font-size:11px">sur la base imposable de ${sfmt(baseImpos)}</span></div>`;}
  document.getElementById('s-bareme-body').innerHTML=`<div class="bareme-pills-row"><span class="abatt-chip">Abattement ${sfmt(b.abatt)}${abattTotal>b.abatt?' + 159 325 € (handicap) = '+sfmt(abattTotal):''}</span></div><div class="tranches-bar">${segs}</div>${tmiInfo}<p style="font-size:11px;color:var(--gray-300);margin-top:8px">${lien==='frere-soeur'?'Exonération totale possible : célibataire/veuf(ve)/divorcé(e), +50 ans ou invalide, domicilié avec le défunt 5 ans.':'Droits calculés par tranches progressives sur la part nette après abattement (art. 777 CGI).'}</p>`;
}

/* ── Arbre généalogique ── */
function drawTree(actif, results){
  const container=document.getElementById('s-tree-container');
  if(!container)return;
  const n=results.length;
  if(n===0){container.innerHTML='<p style="font-size:12px;color:var(--gray-300);padding:1rem;text-align:center">Ajoutez des héritiers pour voir l\'arbre généalogique.</p>';return;}

  const W=Math.max(680,n*180+120), H=200;
  const cx=W/2, topY=44, botY=152;
  const nodeW=140, nodeH=72;
  const xPositions=results.map((_,i)=>Math.round((i+.5)*W/n));

  let svg=`<svg viewBox="0 0 ${W} ${H}" width="100%" xmlns="http://www.w3.org/2000/svg" style="font-family:var(--font-sans,'Source Sans 3',sans-serif)">`;

  /* Défunt — nœud central haut */
  svg+=`<rect x="${cx-65}" y="4" width="130" height="40" rx="6" fill="#a50013" />`;
  svg+=`<text x="${cx}" y="20" text-anchor="middle" font-size="11" font-weight="500" fill="white">Défunt</text>`;
  svg+=`<text x="${cx}" y="35" text-anchor="middle" font-size="11" fill="rgba(255,255,255,.8)">${sfmt(actif)}</text>`;

  /* Ligne horizontale commune */
  const xMin=xPositions[0],xMax=xPositions[xPositions.length-1];
  const hLineY=topY+40+20;
  svg+=`<line x1="${cx}" y1="${topY+40}" x2="${cx}" y2="${hLineY}" stroke="#c8c2c2" stroke-width="1.5"/>`;
  if(n>1){svg+=`<line x1="${xMin}" y1="${hLineY}" x2="${xMax}" y2="${hLineY}" stroke="#c8c2c2" stroke-width="1.5"/>`;}

  results.forEach((r,i)=>{
    const x=xPositions[i];
    const b=SBC[r.lien];
    const exo=b&&b.exonere;
    const nodeBg=exo?'#EAF3DE':r.droits>0?'#fde8eb':'#E6F1FB';
    const nodeBorder=exo?'#639922':r.droits>0?'#a50013':'#185FA5';
    const labelColor=exo?'#27500A':r.droits>0?'#7a000e':'#0C447C';
    const label=r.nom||(b?b.label:'Héritier');

    /* Ligne verticale vers héritier */
    svg+=`<line x1="${x}" y1="${hLineY}" x2="${x}" y2="${botY-nodeH/2}" stroke="#c8c2c2" stroke-width="1.5"/>`;

    /* Nœud héritier */
    const nx=x-nodeW/2, ny=botY-nodeH/2;
    svg+=`<rect x="${nx}" y="${ny}" width="${nodeW}" height="${nodeH}" rx="8" fill="${nodeBg}" stroke="${nodeBorder}" stroke-width="1.5"/>`;

    /* Avatar cercle */
    svg+=`<circle cx="${nx+22}" cy="${ny+nodeH/2}" r="14" fill="${nodeBorder}" opacity=".15"/>`;
    svg+=`<text x="${nx+22}" y="${ny+nodeH/2+4}" text-anchor="middle" font-size="12" font-weight="600" fill="${nodeBorder}">${label.charAt(0).toUpperCase()}</text>`;

    /* Nom */
    const dispName=label.length>14?label.slice(0,13)+'…':label;
    svg+=`<text x="${nx+42}" y="${ny+18}" font-size="11.5" font-weight="600" fill="${labelColor}">${dispName}</text>`;
    /* Lien */
    const lienLabel=b?b.label:'—';
    const dispLien=lienLabel.length>16?lienLabel.slice(0,15)+'…':lienLabel;
    svg+=`<text x="${nx+42}" y="${ny+32}" font-size="10" fill="${labelColor}" opacity=".75">${dispLien}</text>`;
    /* Quote-part */
    svg+=`<text x="${nx+42}" y="${ny+46}" font-size="10" fill="${labelColor}" opacity=".75">${Math.round(r.qpct)} % de la succession</text>`;
    /* Montant net */
    const netLabel=exo?'Exonéré':sfmtK(r.netAvecAV);
    svg+=`<text x="${nx+nodeW/2}" y="${ny+nodeH-8}" text-anchor="middle" font-size="12" font-weight="600" fill="${nodeBorder}">${netLabel}</text>`;

    /* Badge droits si non exo */
    if(!exo&&r.droits>0){
      const badgeX=x+nodeW/2-14, badgeY=ny-10;
      svg+=`<rect x="${badgeX-28}" y="${badgeY-11}" width="56" height="18" rx="9" fill="#e2001a"/>`;
      svg+=`<text x="${badgeX}" y="${badgeY+1}" text-anchor="middle" font-size="9.5" font-weight="600" fill="white">−${sfmtK(r.droits)}</text>`;
    }
  });

  svg+=`</svg>`;
  container.innerHTML=svg;
}

function computeS(){
  const actif=sn('s-actif'),passif=sn('s-passif');
  const avM=sn('s-av-montant'),avAge=document.getElementById('s-av-age').value;
  const avR=(parseFloat(document.getElementById('s-av-rdt').value)||0)/100;
  const avD=Math.max(1,parseInt(document.getElementById('s-av-duree').value)||15);
  const donTotal=sDons.reduce((s,d)=>s+d.m,0);
  const avExAv70=sAvExist.filter(a=>a.age==='avant70').reduce((s,a)=>s+a.p,0);
  const avExAp70=sAvExist.filter(a=>a.age==='apres70').reduce((s,a)=>s+a.p,0);
  const avExTot=avExAv70+avExAp70;
  const avCap=Math.round(avM*Math.pow(1+avR,avD));

  /* Héritiers — si aucun, on utilise un héritier enfant fictif à 100% pour les métriques */
  const hers=sHeritiers.length>0?sHeritiers:[{id:-1,nom:'',lien:'enfant',qpct:100,handicap:false}];

  /* Calcul par héritier */
  const results=hers.map(h=>{
    const q=h.qpct/100;
    const b=SBC[h.lien];
    const ab=(b.exonere?0:b.abatt)+(h.handicap&&!b.exonere?159325:0);

    /* Scénario 0 : sans AV */
    const an0=Math.max(0,actif-passif);
    const pb0=an0*q,bi0=Math.max(0,pb0+donTotal*q-ab);
    const{d:dr0}=calcSD(bi0,h.lien),net0=Math.max(0,pb0-dr0);

    /* AV existantes */
    const dAvExAv70=calcSDAV(avExAv70,'avant70',h.lien,ab);
    const dAvExAp70=calcSDAV(avExAp70*q,'apres70',h.lien,ab);
    const avExNet=avExAv70-dAvExAv70+(avExAp70*q-dAvExAp70);
    const an1=Math.max(0,actif-avExTot-passif);
    const pb1=an1*q,bi1=Math.max(0,pb1+donTotal*q-ab);
    const{d:dr1}=calcSD(bi1,h.lien),netSucc1=Math.max(0,pb1-dr1),net1=netSucc1+avExNet;

    /* Scénario 2 : AV existantes + nouveau */
    const an2=Math.max(0,actif-avExTot-avM-passif);
    const pb2=an2*q,bi2=Math.max(0,pb2+donTotal*q-ab);
    const{d:dr2}=calcSD(bi2,h.lien);
    const dAvNew=calcSDAV(avAge==='avant70'?avCap:avM*q,avAge,h.lien,ab);
    const avNewNet=Math.max(0,avCap-dAvNew);
    const netSucc2=Math.max(0,pb2-dr2),net2=netSucc2+avExNet+avNewNet;
    const txEff0=pb0>0?dr0/pb0:0,txEff2=(pb2+avCap)>0?(dr2+dAvNew)/(pb2+avCap):0;
    const gainAV=net1-net0,gainTot=net2-net0;

    return{nom:h.nom,lien:h.lien,qpct:h.qpct,handicap:h.handicap,
      pb0,bi0,dr0,net0,txEff0,
      avExNet,dr1,netSucc1,net1,gainAV,
      pb2,bi2,dr2,dAvNew,avNewNet,netSucc2,net2,gainTot,txEff2,
      droits:dr2+dAvNew+dAvExAv70+dAvExAp70,netAvecAV:net2,
      dAvExAv70,dAvExAp70,avExTot};
  });

  /* Affichage métriques KPI — basé sur le premier héritier */
  const r0=results[0];
  const avExNet0=r0.avExNet,dr10=r0.dr1,dAvExAv70_0=r0.dAvExAv70,dAvExAp70_0=r0.dAvExAp70;
  sset('sk0',sfmt(r0.dr0));sset('sk0s','Taux effectif : '+sfmtPct(r0.txEff0*100));
  sset('sk1',sfmt(r0.dr1+r0.dAvExAv70+r0.dAvExAp70));sset('sk1s','Écon. : '+sfmt(Math.max(0,r0.dr0-(r0.dr1+r0.dAvExAv70+r0.dAvExAp70))));
  sset('sk2',sfmt(r0.dr2+r0.dAvNew+r0.dAvExAv70+r0.dAvExAp70));sset('sk2s','Taux effectif : '+sfmtPct(r0.txEff2*100));
  sset('sk3',sfmt(Math.max(0,r0.dr0-(r0.dr2+r0.dAvNew))));sset('sk3s',r0.gainTot>0?'+'+sfmt(r0.gainTot)+' de capital':'-');

  /* Récap input */
  const an2_0=Math.max(0,actif-avExTot-avM-passif);
  sset('s-ri-brut',sfmt(actif));sset('s-ri-avex',avExTot>0?'− '+sfmt(avExTot):'0 €');sset('s-ri-avnew',avM>0?'− '+sfmt(avM):'0 €');sset('s-ri-passif',passif>0?'− '+sfmt(passif):'0 €');sset('s-ri-net',sfmt(an2_0));

  /* Barre patrimoine */
  const segs=[{v:an2_0,c:'#5F5E5A',l:'Actif successoral net'},{v:avExTot,c:'#5DCAA5',l:'AV existantes'},{v:avM,c:'#378ADD',l:'Versement AV envisagé'},{v:passif,c:'#E24B4A',l:'Passif'}].filter(x=>x.v>0);
  const pbar=document.getElementById('s-pat-bar'),pleg=document.getElementById('s-pat-leg');pbar.innerHTML='';pleg.innerHTML='';sset('s-pat-tot',sfmt(actif));
  segs.forEach(sg=>{const w=Math.max(0,(sg.v/Math.max(actif,1))*100);pbar.innerHTML+=`<div class="pat-seg" style="width:${w.toFixed(1)}%;background:${sg.c}">${w>7?sfmtK(sg.v):''}</div>`;pleg.innerHTML+=`<span class="pat-leg-i"><span class="pat-leg-sq" style="background:${sg.c}"></span>${sg.l} — ${sfmt(sg.v)}</span>`;});

  /* Flow 3 scénarios (1er héritier) */
  const ab0=(SBC[r0.lien].exonere?0:SBC[r0.lien].abatt)+(r0.handicap&&!SBC[r0.lien].exonere?159325:0);
  sset('ss0-pb',sfmt(r0.pb0));sset('ss0-ab',sfmt(Math.min(ab0,r0.pb0)));sset('ss0-bi',sfmt(r0.bi0));sset('ss0-dr',sfmt(r0.dr0));sset('ss0-net',sfmt(r0.net0));
  sset('ss1-pb',sfmt(r0.pb2+(avExTot*(r0.qpct/100))));sset('ss1-dr',sfmt(r0.dr1));sset('ss1-av',sfmt(r0.avExNet));sset('ss1-net',sfmt(r0.net1));
  ssetH('ss1-delta',r0.gainAV>0?`↑ +${sfmt(r0.gainAV)} vs sans AV`:'Sans gain vs sans AV');
  sset('ss2-pb',sfmt(r0.pb2));sset('ss2-dr',sfmt(r0.dr2));sset('ss2-av-ex',sfmt(r0.avExNet));sset('ss2-av-new',sfmt(r0.avNewNet));sset('ss2-net',sfmt(r0.net2));
  ssetH('ss2-delta',r0.gainTot>0?`↑ +${sfmt(r0.gainTot)} vs sans AV`:'Sans gain vs sans AV');

  /* Barème — 1er héritier */
  renderBaremeCtx(r0.lien,r0.bi0,r0.handicap);

  /* Arbre généalogique */
  drawTree(actif,results);

  /* Graphiques (1er héritier) */
  const ctxB=document.getElementById('s-ch-bar');
  if(sBarChart){sBarChart.destroy();sBarChart=null;}
  sBarChart=new Chart(ctxB,{type:'bar',data:{labels:['Sans AV','Avec AV existantes','+ Versement nouveau'],datasets:[{label:'Succession nette',data:[Math.round(r0.net0),Math.round(r0.netSucc1),Math.round(r0.netSucc2)],backgroundColor:'#1D9E75',borderSkipped:false,borderRadius:0},{label:'AV existantes nettes',data:[0,Math.round(r0.avExNet),Math.round(r0.avExNet)],backgroundColor:'#5DCAA5',borderSkipped:false,borderRadius:0},{label:'AV nouvelle nette',data:[0,0,Math.round(r0.avNewNet)],backgroundColor:'#85B7EB',borderSkipped:false,borderRadius:0},{label:'Droits',data:[Math.round(r0.dr0),Math.round(r0.dr1+r0.dAvExAv70+r0.dAvExAp70),Math.round(r0.dr2+r0.dAvNew+r0.dAvExAv70+r0.dAvExAp70)],backgroundColor:'#E24B4A',borderRadius:{topLeft:4,topRight:4,bottomLeft:0,bottomRight:0},borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,scales:{x:{stacked:true,grid:{display:false},ticks:{color:'#7a7272',font:{size:10}}},y:{stacked:true,border:{display:false},grid:{color:'rgba(0,0,0,0.04)'},ticks:{color:'#7a7272',font:{size:10},callback:v=>v>=1000000?(v/1000000).toFixed(1)+' M€':v>=1000?(v/1000).toFixed(0)+' k€':v+'€'}}},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>{const v=c.raw;return v>0?` ${Math.round(v).toLocaleString('fr-FR')} €`:null;}}}}}});

  const ctxD=document.getElementById('s-ch-donut');
  if(sDonutChart){sDonutChart.destroy();sDonutChart=null;}
  const dData=[{v:Math.round(r0.netSucc2),c:'#1D9E75',l:'Succession nette'},{v:Math.round(r0.avExNet),c:'#5DCAA5',l:'AV existantes'},{v:Math.round(r0.avNewNet),c:'#85B7EB',l:'AV nouvelle'},{v:Math.round(r0.dr2),c:'#E24B4A',l:'Droits succession'},{v:Math.round(r0.dAvNew+r0.dAvExAv70+r0.dAvExAp70),c:'#F09595',l:'Droits AV'}].filter(d=>d.v>0);
  const dTot=dData.reduce((s,d)=>s+d.v,0);
  document.getElementById('s-donut-leg').innerHTML=dData.map(d=>`<span class="leg-i"><span class="leg-sq" style="background:${d.c}"></span>${d.l} (${sfmtPct(dTot>0?d.v/dTot*100:0)})</span>`).join('');
  sDonutChart=new Chart(ctxD,{type:'doughnut',data:{labels:dData.map(d=>d.l),datasets:[{data:dData.map(d=>d.v),backgroundColor:dData.map(d=>d.c),borderWidth:2,borderColor:'#fff',hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false,cutout:'62%',plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>{const v=c.raw,p=sfmtPct(dTot>0?v/dTot*100:0);return ` ${Math.round(v).toLocaleString('fr-FR')} € (${p})`;}}}}
}});

  /* Phrase récapitulative — tous héritiers */
  const ll=SBC[r0.lien].label;
  const pctG=r0.net0>0?Math.round(r0.gainTot/r0.net0*100):0;
  const nomH=r0.nom||(sHeritiers.length===0?ll:null);
  const autresH=results.slice(1).map(r=>r.nom||SBC[r.lien].label).filter(Boolean);
  const tousH=nomH?[nomH,...autresH]:autresH.length?autresH:[ll];
  const hLabel=tousH.length===1?`<strong>${tousH[0]}</strong>`:tousH.slice(0,-1).map(n=>`<strong>${n}</strong>`).join(', ')+` et <strong>${tousH[tousH.length-1]}</strong>`;
  let recap='';
  if(SBC[r0.lien].exonere&&results.length===1){recap=`${hLabel} est <strong>totalement exonéré</strong> de droits de succession. Le patrimoine brut de <strong>${sfmt(actif)}</strong> est transmis intégralement en franchise d'impôt (loi TEPA 2007).`;}
  else if(results.length>1){
    const totalDroits=results.reduce((s,r)=>s+r.droits,0);
    const totalNet=results.reduce((s,r)=>s+r.netAvecAV,0);
    const lignes=results.map(r=>`${r.nom?`<strong>${r.nom}</strong>`:('<strong>'+SBC[r.lien].label+'</strong>')} reçoit <strong>${sfmt(r.netAvecAV)}</strong> nets (${Math.round(r.qpct)} %)`);
    recap=`Sur un patrimoine brut de <strong>${sfmt(actif)}</strong>, la succession est répartie entre ${hLabel}. Dans le scénario optimal (avec assurance-vie), le capital net total transmis s'élève à <strong>${sfmt(totalNet)}</strong> après <strong>${sfmt(totalDroits)}</strong> de droits : ${lignes.join(' ; ')}.`;
  }
  else if(r0.gainTot<=0&&r0.gainAV<=0&&avExTot===0){recap=`Sur un patrimoine brut de <strong>${sfmt(actif)}</strong>, ${hLabel} recevrait <strong>${sfmt(r0.net0)}</strong> nets, après acquittement de <strong>${sfmt(r0.dr0)}</strong> de droits de succession (taux effectif de <strong>${sfmtPct(r0.txEff0*100)}</strong>).`;}
  else if(avM===0&&avExTot>0){recap=`Grâce aux <strong>${sfmt(avExTot)}</strong> placés en assurance-vie, ${hLabel} recevrait <strong>${sfmt(r0.net1)}</strong> nets, contre <strong>${sfmt(r0.net0)}</strong> sans assurance-vie — soit <strong>+${sfmt(r0.gainAV)}</strong> de capital supplémentaire et <strong>${sfmt(Math.max(0,r0.dr0-r0.dr1))}</strong> de droits économisés.`;}
  else if(avM>0){recap=`En combinant${avExTot>0?' les <strong>'+sfmt(avExTot)+'</strong> de contrats AV existants et':''} un versement de <strong>${sfmt(avM)}</strong>${avR>0?' (valorisé à '+sfmt(avCap)+' dans '+avD+' ans à '+(avR*100).toFixed(1)+' %/an)':''}, ${hLabel} recevrait <strong>${sfmt(r0.net2)}</strong> nets — contre <strong>${sfmt(r0.net0)}</strong> sans assurance-vie. Soit <strong>+${sfmt(r0.gainTot)}</strong> de capital supplémentaire (+${pctG} %) et <strong>${sfmt(Math.max(0,r0.dr0-r0.dr2-r0.dAvNew))}</strong> de droits économisés.`;}
  else{recap=`Sur un patrimoine brut de <strong>${sfmt(actif)}</strong>, ${hLabel} recevrait <strong>${sfmt(r0.net0)}</strong> nets après <strong>${sfmt(r0.dr0)}</strong> de droits de succession.`;}
  const sRel=document.getElementById('s-recap-text');if(sRel){sRel.innerHTML=recap;sRel.style.color='var(--gray-800)';}

  let info='';
  if(avAge==='avant70'&&avM>0)info+=`<div class="info-box ib-info"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><span>Versement avant 70 ans (art. 757 B) : abattement <strong>152 500 €</strong> / bénéficiaire. Les intérêts capitalisés sont totalement exonérés.</span></div>`;
  if(avAge==='apres70'&&avM>0)info+=`<div class="info-box ib-warning"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><span>Versement après 70 ans (art. 990 I) : abattement global de <strong>30 500 €</strong> tous bénéficiaires. Préférer les versements avant 70 ans.</span></div>`;
  if(results.some(r=>r.lien==='frere-soeur'))info+=`<div class="info-box ib-info"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><span>Exonération totale possible si : célibataire/veuf(ve)/divorcé(e), âgé(e) de + 50 ans ou invalide, domicilié avec le défunt 5 ans.</span></div>`;
  if(donTotal>0)info+=`<div class="info-box ib-info"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><span>Donations antérieures : <strong>${sfmt(donTotal)}</strong> rappelés fiscalement. Les abattements se rechargent tous les 15 ans.</span></div>`;
  document.getElementById('s-info-zone').innerHTML=info;
}

document.getElementById('s-av-age').addEventListener('change',computeS);

/* Init héritiers : 2 enfants par défaut */
addHeritier();
addHeritier();
sHeritiers[0].nom='';sHeritiers[1].nom='';
sHeritiers[0].qpct=50;sHeritiers[1].qpct=50;
renderHeritiers();
</script>
