            <div class="field">
              <span class="field-label">Revenu net imposable</span>
              <div class="mode-tabs"><button class="mtab active" id="tab-rev-slider" onclick="switchRevMode('slider')">Curseur</button><button class="mtab" id="tab-rev-free" onclick="switchRevMode('free')">Saisie libre</button></div>
              <div id="mode-rev-slider"><div class="slider-wrap"><input type="range" id="revenu-range" min="0" max="10000000" step="1000" value="80000" oninput="syncRevFromSlider()"><span class="slider-val" id="revenu-display-range">80 000 €</span></div><div class="slider-minmax"><span>0 €</span><span>10 000 000 €</span></div></div>
              <div id="mode-rev-free" style="display:none"><div class="num-input-wrap"><input type="number" id="revenu-input" min="0" step="100" value="80000" oninput="syncRevFromInput()"><span class="num-input-unit">€</span></div><div class="input-hint">Montant libre, sans plafond</div></div>
