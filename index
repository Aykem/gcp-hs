const TRANCHES=[{min:0,max:11600,taux:0,label:"0%"},{min:11600,max:29579,taux:0.11,label:"11%"},{min:29579,max:84577,taux:0.30,label:"30%"},{min:84577,max:181917,taux:0.41,label:"41%"},{min:181917,max:Infinity,taux:0.45,label:"45%"}];
const COLORS=["#e8c0c4","#f0808a","#e2001a","#a50013","#7a000e"];
const TMI_STYLES=[{bg:"#f7f6f6",color:"#7a7272"},{bg:"#fde8eb",color:"#a50013"},{bg:"#fcd0d5",color:"#7a000e"},{bg:"#f9a8b0",color:"#5a0008"},{bg:"#f06070",color:"#3a0005"}];
let currentRevenu=80000,currentPer=5000,currentParts=2,reportActif=false,stratMode='manuel',selectedDescente=null;

function switchRevMode(m){['slider','free'].forEach(x=>{document.getElementById('tab-rev-'+x).classList.toggle('active',x===m);document.getElementById('mode-rev-'+x).style.display=x===m?'':'none';});}
function syncRevFromSlider(){currentRevenu=parseInt(document.getElementById('revenu-range').value)||0;document.getElementById('revenu-input').value=currentRevenu;updateSliderFill(document.getElementById('revenu-range'));update();}
function syncRevFromInput(){currentRevenu=Math.max(0,parseInt(document.getElementById('revenu-input').value)||0);const s=document.getElementById('revenu-range');s.value=Math.min(currentRevenu,10000000);updateSliderFill(s);update();}
function switchPartsMode(m){['slider','free'].forEach(x=>{document.getElementById('tab-parts-'+x).classList.toggle('active',x===m);document.getElementById('mode-parts-'+x).style.display=x===m?'':'none';});}
function syncPartsFromSlider(){currentParts=parseFloat(document.getElementById('parts-range').value);document.getElementById('parts-input').value=currentParts;updateSliderFill(document.getElementById('parts-range'));update();}
function syncPartsFromInput(){let v=parseFloat(document.getElementById('parts-input').value)||1;v=Math.min(Math.max(Math.round(v*4)/4,1),10);currentParts=v;document.getElementById('parts-input').value=v;const s=document.getElementById('parts-range');s.value=v;updateSliderFill(s);update();}
function switchPerMode(m){['slider','free'].forEach(x=>{document.getElementById('tab-per-'+x).classList.toggle('active',x===m);document.getElementById('mode-per-'+x).style.display=x===m?'':'none';});}
function syncPerFromSlider(){currentPer=parseInt(document.getElementById('per-range').value)||0;document.getElementById('per-input').value=currentPer;updateSliderFill(document.getElementById('per-range'));update();}
function syncPerFromInput(){currentPer=Math.max(0,parseInt(document.getElementById('per-input').value)||0);update();}
function toggleReport(){reportActif=!reportActif;document.getElementById('toggle-btn').classList.toggle('on',reportActif);document.getElementById('report-section').style.maxHeight=reportActif?'300px':'0';update();}
function getReports(){if(!reportActif)return{n1:0,n2:0,n3:0,total:0};const n1=Math.max(0,parseInt(document.getElementById('report-n1').value)||0),n2=Math.max(0,parseInt(document.getElementById('report-n2').value)||0),n3=Math.max(0,parseInt(document.getElementById('report-n3').value)||0);return{n1,n2,n3,total:n1+n2+n3};}
function switchStrat(m){stratMode=m;selectedDescente=null;['manuel','optimal','descente'].forEach(s=>{document.getElementById('strat-'+s).classList.toggle('active',s===m);document.getElementById('zone-'+s).style.display=s===m?'':'none';});update();}
function calcIR(qi){let imp=0;for(const t of TRANCHES){if(qi<=t.min)break;imp+=(Math.min(qi,t.max===Infinity?qi:t.max)-t.min)*t.taux;}return Math.round(imp);}
function calcIRTotal(rev,parts){return Math.round(calcIR(rev/parts)*parts);}
function getTMIIndex(rev,parts){const qi=rev/parts;let idx=0;TRANCHES.forEach((t,i)=>{if(qi>t.min)idx=i;});return idx;}
function fmt(n){return Math.round(n).toLocaleString('fr-FR')+' €';}
function pct(n){return Math.round(n*100)+' %';}
function getPlafondAnnuel(rev){return Math.min(Math.max(Math.round(.1*rev),Math.round(.1*46368)),35194);}
function updateSliderFill(el){const p=(el.value-el.min)/(el.max-el.min)*100;el.style.setProperty('--pct',p+'%');}
function optimalPer(rev,parts,plafond){const irAv=calcIRTotal(rev,parts);let bestM=0,bestEco=0,bestTaux=0;const step=plafond>100000?500:100;for(let v=step;v<=plafond;v+=step){const eco=irAv-calcIRTotal(Math.max(0,rev-v),parts);if(eco>bestEco){bestEco=eco;bestM=v;bestTaux=eco/v;}}const iA=getTMIIndex(rev,parts),iB=getTMIIndex(Math.max(0,rev-bestM),parts);return{montant:bestM,economie:bestEco,taux:bestTaux,changeTranche:iB<iA,nouvelleTranche:TRANCHES[iB].label};}
function versementPourDescente(rev,parts,cibleIdx){return Math.ceil((rev/parts-TRANCHES[cibleIdx].max)*parts/100)*100;}
function calcDescenteOptions(rev,parts,plafond){const tmiIdx=getTMIIndex(rev,parts),irAv=calcIRTotal(rev,parts),opts=[];for(let c=tmiIdx-1;c>=0;c--){const v=versementPourDescente(rev,parts,c),possible=v>0&&v<=plafond;const eco=possible?irAv-calcIRTotal(Math.max(0,rev-v),parts):null;opts.push({de:TRANCHES[tmiIdx],vers:TRANCHES[c],deIdx:tmiIdx,versIdx:c,montant:v,possible,economie:eco,taux:possible&&v>0?eco/v:null});}return opts;}
function renderDescenteCards(opts,plafond){const c=document.getElementById('descente-cards');if(!opts.length){c.innerHTML='<p style="font-size:12px;color:var(--gray-500)">Déjà dans la tranche à 0 %, aucune descente possible.</p>';return;}c.innerHTML='';opts.forEach(opt=>{const card=document.createElement('div');card.className='descente-card'+(opt===selectedDescente?' selected':'')+(opt.possible?'':' impossible');const s1=TMI_STYLES[opt.deIdx],s2=TMI_STYLES[opt.versIdx];let html=`<div class="descente-header-row"><div class="descente-pills"><span class="tpill" style="background:${s1.bg};color:${s1.color}">${opt.de.label}</span><span style="color:var(--gray-300)">→</span><span class="tpill" style="background:${s2.bg};color:${s2.color}">${opt.vers.label}</span></div>${opt.possible?`<span class="descente-amount">${fmt(opt.montant)}</span>`:'<span style="font-size:11px;color:var(--gray-300)">Hors plafond</span>'}</div>`;if(opt.possible)html+=`<div class="descente-detail">Économie : <strong>${fmt(opt.economie)}</strong> · ${pct(opt.taux)} de déduction</div>`;else html+=`<div class="descente-detail">Versement requis ${fmt(opt.montant)} > plafond ${fmt(plafond)}</div>`;card.innerHTML=html;if(opt.possible){card.onclick=()=>{selectedDescente=opt;currentPer=opt.montant;const pr=document.getElementById('per-range');pr.value=Math.min(opt.montant,plafond);document.getElementById('per-input').value=opt.montant;document.getElementById('per-display-range').textContent=fmt(opt.montant);updateSliderFill(pr);renderDescenteCards(opts,plafond);updateResults(currentRevenu,currentParts,opt.montant,plafond);};}card.appendChild(document.createTextNode(''));c.appendChild(card);});}

function updateResults(revenu,parts,per,plafondTotal){
  const irAv=calcIRTotal(revenu,parts),revAp=Math.max(0,revenu-per);
  const irAp=calcIRTotal(revAp,parts),eco=irAv-irAp,taux=per>0?eco/per:0;
  document.getElementById('ir-avant').textContent=fmt(irAv);
  document.getElementById('ir-apres').textContent=fmt(irAp);
  document.getElementById('economie').textContent=fmt(eco);
  document.getElementById('taux-ded').textContent=pct(taux);
  const i1=getTMIIndex(revenu,parts),i2=getTMIIndex(revAp,parts);
  const b1=document.getElementById('tmi-badge');b1.textContent=TRANCHES[i1].label;b1.style.background=TMI_STYLES[i1].bg;b1.style.color=TMI_STYLES[i1].color;
  const b2=document.getElementById('tmi-after-badge');b2.textContent=TRANCHES[i2].label;b2.style.background=TMI_STYLES[i2].bg;b2.style.color=TMI_STYLES[i2].color;
  const bar=document.getElementById('tmi-bar'),leg=document.getElementById('bar-legend');bar.innerHTML='';leg.innerHTML='';
  const total=Math.max(revenu,1);TRANCHES.forEach((t,i)=>{if(t.min>=total)return;const base=Math.min(total,t.max===Infinity?total:t.max)-t.min;bar.innerHTML+=`<div class="tmi-seg" style="width:${(base/total*100).toFixed(1)}%;background:${COLORS[i]}"></div>`;leg.innerHTML+=`<div class="tmi-legend-item"><div class="tmi-legend-dot" style="background:${COLORS[i]}"></div>${t.label}</div>`;});
  const tbody=document.getElementById('tranche-body');tbody.innerHTML='';const qi=revenu/parts;TRANCHES.forEach((t,i)=>{const active=qi>t.min,maxLabel=t.max===Infinity?'+∞':fmt(t.max*parts);const tr=document.createElement('tr');if(active)tr.className='active';const dot=`<span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:${COLORS[i]};margin-right:5px;vertical-align:middle"></span>`;tr.innerHTML=`<td>${dot}<strong>${t.label}</strong></td><td>${fmt(t.min*parts)}</td><td>${maxLabel}</td><td style="text-align:center">${active?'<span style="color:var(--red);font-weight:700">✓</span>':''}</td>`;tbody.appendChild(tr);});

  /* ── PHRASE RECAP PER ── */
  const irAv2=irAv,irAp2=irAp,eco2=eco;
  const tmi1=TRANCHES[i1].label,tmi2=TRANCHES[i2].label;
  const tauxEff=revenu>0?eco2/revenu:0;
  let recap='';
  if(per===0){
    recap=`Sur un revenu net imposable de <strong>${fmt(revenu)}</strong> (${parts} part${parts>1?'s':''}), l'impôt sur le revenu s'élève à <strong>${fmt(irAv2)}</strong> — taux effectif de <strong>${pct(revenu>0?irAv2/revenu:0)}</strong>, tranche marginale à <strong>${tmi1}</strong>. Aucun versement PER n'est renseigné. Utilisez l'optimisation automatique pour calculer l'économie maximale possible.`;
  } else if(eco2<=0){
    recap=`Sur un revenu de <strong>${fmt(revenu)}</strong>, un versement PER de <strong>${fmt(per)}</strong> ne génère pas d'économie d'impôt dans ce scénario (revenu inférieur au seuil d'imposition).`;
  } else {
    const descenteTranche=i2<i1?` Le versement permet également de <strong>descendre dans la tranche à ${tmi2}</strong> (contre ${tmi1} sans PER) — un avantage fiscal durable sur l'ensemble de la base imposable.`:'';
    const coutReel=per-eco2;
    const rendImplicite=per>0?Math.round(eco2/per*1000)/10:0;
    recap=`En versant <strong>${fmt(per)}</strong> sur le Plan d'Épargne Retraite, votre client <strong>réduit immédiatement son impôt de ${fmt(eco2)}</strong> — son IR passe de <strong>${fmt(irAv2)}</strong> à <strong>${fmt(irAp2)}</strong>. Le coût réel de l'effort d'épargne n'est donc que de <strong>${fmt(coutReel)}</strong> après déduction fiscale, avec un <strong>rendement fiscal immédiat de ${rendImplicite} %</strong> sur le versement (taux de déduction : <strong>${pct(taux)}</strong> à la TMI de <strong>${tmi1}</strong>).${descenteTranche} Ce versement s'inscrit dans un plafond disponible de <strong>${fmt(plafondTotal)}</strong>.`;
  }
  const el=document.getElementById('per-recap-text');if(el){el.innerHTML=recap;el.style.color='var(--gray-800)';}
}

function update(){
  const revenu=currentRevenu,parts=currentParts,reports=getReports();
  const plafondAnnuel=getPlafondAnnuel(revenu),plafondTotal=plafondAnnuel+reports.total;
  document.getElementById('revenu-display-range').textContent=fmt(revenu);document.getElementById('revenu-input').value=revenu;
  document.getElementById('parts-display').textContent=parts+(parts<=1?' part':' parts');
  document.getElementById('report-total').textContent=fmt(reports.total);
  const pr=document.getElementById('per-range');pr.max=plafondTotal;document.getElementById('per-max-label').textContent=fmt(plafondTotal);document.getElementById('per-plafond-hint').textContent=fmt(plafondTotal);updateSliderFill(pr);
  let per=currentPer;
  if(stratMode==='optimal'){const opt=optimalPer(revenu,parts,plafondTotal);per=opt.montant;currentPer=per;pr.value=per;document.getElementById('per-input').value=per;document.getElementById('per-display-range').textContent=fmt(per);updateSliderFill(pr);document.getElementById('reco-optimal').innerHTML=`<div class="reco-box"><div class="reco-title">Versement optimal recommandé</div><div class="reco-amount">${fmt(opt.montant)}</div><div class="reco-detail">Économie fiscale : <strong>${fmt(opt.economie)}</strong> · ${pct(opt.taux)} de déduction</div>${opt.changeTranche?`<div class="reco-badge">↓ Bascule en tranche ${opt.nouvelleTranche}</div>`:''}</div>`;}
  else if(stratMode==='descente'){const opts=calcDescenteOptions(revenu,parts,plafondTotal);if(selectedDescente&&selectedDescente.possible&&selectedDescente.montant<=plafondTotal)per=selectedDescente.montant;else selectedDescente=null;pr.value=Math.min(per,plafondTotal);document.getElementById('per-input').value=per;document.getElementById('per-display-range').textContent=fmt(Math.min(per,plafondTotal));updateSliderFill(pr);renderDescenteCards(opts,plafondTotal);}
  else{per=Math.max(0,currentPer);pr.value=Math.min(per,plafondTotal);document.getElementById('per-display-range').textContent=fmt(Math.min(per,plafondTotal));document.getElementById('per-input').value=per;updateSliderFill(pr);}
  const depasse=per>plafondTotal;document.getElementById('per-warn').style.display=depasse?'flex':'none';const perEffectif=depasse?plafondTotal:per;
  const p10=Math.round(.1*revenu),pMin=Math.round(.1*46368);let html=`<div class="plafond-line"><span class="lbl">10% du revenu net imposable</span><span class="val">${fmt(p10)}</span></div><div class="plafond-line"><span class="lbl">10% du PASS 2026 (plancher)</span><span class="val">${fmt(pMin)}</span></div><div class="plafond-line"><span class="lbl">Plafond annuel (max 35 194 €)</span><span class="val" style="color:var(--red)">${fmt(plafondAnnuel)}</span></div>`;
  if(reportActif&&reports.total>0){if(reports.n1)html+=`<div class="plafond-line"><span class="lbl" style="padding-left:10px">+ Report N-1</span><span class="val">${fmt(reports.n1)}</span></div>`;if(reports.n2)html+=`<div class="plafond-line"><span class="lbl" style="padding-left:10px">+ Report N-2</span><span class="val">${fmt(reports.n2)}</span></div>`;if(reports.n3)html+=`<div class="plafond-line"><span class="lbl" style="padding-left:10px">+ Report N-3</span><span class="val">${fmt(reports.n3)}</span></div>`;html+=`<div class="plafond-total-line"><span class="lbl">Plafond total disponible</span><span class="val">${fmt(plafondTotal)}</span></div>`;}else{html+=`<p style="font-size:10.5px;color:var(--gray-300);margin-top:5px">Activez le report pour cumuler les plafonds N-1, N-2, N-3.</p>`;}
  document.getElementById('plafond-zone').innerHTML=html;
  updateResults(revenu,parts,perEffectif,plafondTotal);updateSliderFill(document.getElementById('revenu-range'));updateSliderFill(document.getElementById('parts-range'));
}
