function sfmt(v){return Math.round(v).toLocaleString('fr-FR')+' €';}
function sfmtPct(v){return(isNaN(v)||!isFinite(v))?'0 %':(Math.round(v*10)/10)+' %';}
function sfmtK(v){const r=Math.round(v);return r>=1000000?(r/1000000).toFixed(1)+' M€':r>=1000?(r/1000).toFixed(0)+' k€':r+' €';}
function addSAv(){sAvExist.push({id:sAvId++,p:0,age:'avant70'});renderSAv();computeS();}
function removeSAv(id){sAvExist=sAvExist.filter(a=>a.id!==id);renderSAv();computeS();}
function renderSAv(){document.getElementById('s-av-exist-list').innerHTML=sAvExist.map(a=>`<div class="dyn-row"><input type="number" value="${a.p}" min="0" step="5000" placeholder="Primes €" oninput="sAvExist.find(x=>x.id==${a.id}).p=Math.max(0,parseInt(this.value)||0);computeS()"><select onchange="sAvExist.find(x=>x.id==${a.id}).age=this.value;computeS()"><option value="avant70" ${a.age==='avant70'?'selected':''}>Avant 70 ans</option><option value="apres70" ${a.age==='apres70'?'selected':''}>Après 70 ans</option></select><button class="btn-rm" onclick="removeSAv(${a.id})">✕</button></div>`).join('');}
function addSDon(){sDons.push({id:sDonId++,m:0});renderSDons();computeS();}
function removeSDon(id){sDons=sDons.filter(d=>d.id!==id);renderSDons();computeS();}
function renderSDons(){document.getElementById('s-dons-list').innerHTML=sDons.map(d=>`<div class="dyn-row-2"><input type="number" value="${d.m}" min="0" step="1000" placeholder="Montant €" oninput="sDons.find(x=>x.id==${d.id}).m=Math.max(0,parseInt(this.value)||0);computeS()"><button class="btn-rm" onclick="removeSDon(${d.id})">✕</button></div>`).join('');}

