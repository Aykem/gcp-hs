function calcSD(base,lien){const b=SBC[lien];if(!b||b.exonere||!b.tr||base<=0)return{d:0,tm:0};let r=base,c=0,tot=0,tm=0;for(const t of b.tr){if(r<=0)break;const sl=t.max===Infinity?r:Math.min(r,t.max-c);if(sl>0){tot+=sl*t.t;tm=t.t;}r-=sl;c=t.max===Infinity?c+sl:t.max;}return{d:Math.round(tot),tm};}
function calcSDAV(cap,age,lien,ab){if(age==='avant70'){const b=Math.max(0,cap-152500);return b>0?Math.round(Math.min(b,700000)*.20+Math.max(0,b-700000)*.3125):0;}return calcSD(Math.max(0,cap-30500-ab),lien).d;}
function sset(id,v){const el=document.getElementById(id);if(el)el.textContent=v;}
function ssetH(id,v){const el=document.getElementById(id);if(el)el.innerHTML=v;}

